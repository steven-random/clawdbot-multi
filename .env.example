# ============================================================
#  ClawdBot — Environment Variables
#  Copy this to .env and fill in your values
# ============================================================

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack channel names (must match exactly what you create in Slack)
SLACK_CHANNEL_CODE=agent-code
SLACK_CHANNEL_DATA=agent-data
SLACK_CHANNEL_SEARCH=agent-search
SLACK_CHANNEL_DOCS=agent-docs

# ── Postgres ────────────────────────────────────────────────
POSTGRES_USER=clawdbot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=clawdbot

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Capabilities ────────────────────────────────────────────
# email: Yahoo Mail via IMAP/SMTP
# Get App Password: Yahoo Account → Security → Generate app password
EMAIL_ADDRESS=yourname@yahoo.com
EMAIL_APP_PASSWORD=
IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587

# minneru: PDF → Markdown via RunPod Serverless
RUNPOD_API_KEY=
MINNERU_ENDPOINT_ID=

# database: remote SQL database (fill in to enable the database capability)
DATABASE_URL=

# ── Optional: Web Search (Brave/Serper) ─────────────────────
# If not set, the search agent falls back to Claude's knowledge
BRAVE_API_KEY=
SERPER_API_KEY=
